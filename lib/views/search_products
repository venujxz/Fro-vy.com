import 'package:flutter/material.dart';

class  search_products extends StatelessWidget {
  const search_products({super.key});

  // Mock data to match your long list screenshot
  final List<Map<String, String>> ingredients = const [
    {"name": "Whole Grain Oats", "status": "Safe", "desc": "Natural fiber source"},
    {"name": "Honey", "status": "Natural", "desc": "Natural sweetener"},
    {"name": "Almonds", "status": "Safe", "desc": "Healthy fats"},
    {"name": "Sugar", "status": "Caution", "desc": "High glycemic index"},
    {"name": "Palm Oil", "status": "Avoid", "desc": "High saturated fats"},
    // Add more to see the scrolling effect...
  ];

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFF5F5F5),
      appBar: AppBar(
        title: const Text("Analysis Results"),
        backgroundColor: Colors.white,
        foregroundColor: Colors.black,
        elevation: 0.5,
      ),
      body: ListView.builder(
        padding: const EdgeInsets.all(12),
        itemCount: ingredients.length,
        itemBuilder: (context, index) {
          final item = ingredients[index];
          return Card(
            elevation: 0,
            margin: const EdgeInsets.only(bottom: 10),
            shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
            child: ListTile(
              leading: Icon(
                Icons.circle, 
                color: _getStatusColor(item['status']!), 
                size: 15
              ),
              title: Text(item['name']!, style: const TextStyle(fontWeight: FontWeight.bold)),
              subtitle: Text(item['desc']!),
              trailing: const Icon(Icons.chevron_right, color: Colors.grey),
            ),
          );
        },
      ),
    );
  }

  Color _getStatusColor(String status) {
    switch (status) {
      case 'Safe': return Colors.green;
      case 'Caution': return Colors.orange;
      case 'Avoid': return Colors.red;
      default: return Colors.blue;
    }
  }
}