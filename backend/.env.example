# PayHere API Credentials
# Get these from https://sandbox.payhere.lk (sandbox) or https://www.payhere.lk (production)

# Your Merchant ID from PayHere dashboard
PAYHERE_MERCHANT_ID=YOUR_MERCHANT_ID

# Your Merchant Secret from PayHere dashboard (keep this private!)
PAYHERE_MERCHANT_SECRET=YOUR_MERCHANT_SECRET

# Enable sandbox mode for testing (set to false for production)
PAYHERE_SANDBOX=true

# Server port
PORT=3000
