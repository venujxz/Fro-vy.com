# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# PayHere credentials (https://www.payhere.lk/merchant/settings)
PAYHERE_MERCHANT_ID=your_merchant_id_here
PAYHERE_MERCHANT_SECRET=your_merchant_secret_here
PAYHERE_SANDBOX=true

# Google Cloud Vision API (for /analyze-image OCR endpoint)
# The firebase-key.json service account is used automatically via firebase-admin.
# If you get Vision API errors, ensure the service account has the
# "Cloud Vision API" enabled in Google Cloud Console for your project.

# Allowed origin for CORS in production
ALLOWED_ORIGIN=https://your-app-domain.com

# Server port
PORT=3000
